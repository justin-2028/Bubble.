##
## Local development (Supabase Postgres)
##
# For best results, use the pooled (PgBouncer) connection string from Supabase:
# Project Settings → Database → Connection string → URI → Pooled connection
# Example (use a dedicated least-privilege user, not `postgres`):
# DATABASE_URL="postgresql://bubble_app:YOUR_PASSWORD@db.PROJECT_ID.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
# For non‑pooled dev connections you can also use port 5432 without the params.
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.PROJECT_ID.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"

# Prisma Migrate / Introspect (non‑pooled direct connection)
DIRECT_URL="postgresql://bubble_app:YOUR_PASSWORD@db.PROJECT_ID.supabase.co:5432/postgres?sslmode=require"

NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="changeme"
