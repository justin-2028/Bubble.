BUBBLE_ADMIN_USERNAME="admin"
BUBBLE_ADMIN_PASSWORD_HASH=""
BUBBLE_SESSION_SECRET=""
# Recommended separate secret for encrypting hosted Bubble storage. Falls back to BUBBLE_SESSION_SECRET if omitted.
# BUBBLE_STORAGE_SECRET=""
# Optional for local development only. Prefer BUBBLE_ADMIN_PASSWORD_HASH in deployed environments.
# BUBBLE_ADMIN_PASSWORD=""

# Recommended durable hosted store: a Postgres database URL from Neon or another provider.
# Bubble prefers DATABASE_URL in production and stores encrypted app documents there.
# DATABASE_URL=""

# Optional temporary migration source only.
# If DATABASE_URL is set and BLOB_READ_WRITE_TOKEN is still present, Bubble will read missing documents from Blob once
# and copy them into Postgres. After verifying the migration, remove BLOB_READ_WRITE_TOKEN.
# BLOB_READ_WRITE_TOKEN=""
