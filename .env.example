BUBBLE_ADMIN_USERNAME="admin"
BUBBLE_ADMIN_PASSWORD_HASH=""
BUBBLE_SESSION_SECRET=""
# Optional separate secret for encrypting hosted blob storage. Falls back to BUBBLE_SESSION_SECRET.
# BUBBLE_STORAGE_SECRET=""
# Optional for local development only. Prefer BUBBLE_ADMIN_PASSWORD_HASH in deployed environments.
# BUBBLE_ADMIN_PASSWORD=""

# Optional: enables hosted state in Vercel Blob. Without this, Bubble falls back to a local JSON file.
# BLOB_READ_WRITE_TOKEN=""
