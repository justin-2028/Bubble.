BUBBLE_ADMIN_USERNAME="admin"
BUBBLE_ADMIN_PASSWORD_HASH=""
BUBBLE_SESSION_SECRET=""
# Recommended separate secret for encrypting hosted blob storage. Falls back to BUBBLE_SESSION_SECRET if omitted.
# BUBBLE_STORAGE_SECRET=""
# Optional for local development only. Prefer BUBBLE_ADMIN_PASSWORD_HASH in deployed environments.
# BUBBLE_ADMIN_PASSWORD=""

# Required for durable hosted mode on Vercel: enables persistent state in a private Vercel Blob store.
# Create the private Blob store in the same Vercel project so Vercel injects this token automatically.
# Without this, Bubble will only use a local JSON file in `.bubble-data/` during development.
# BLOB_READ_WRITE_TOKEN=""
